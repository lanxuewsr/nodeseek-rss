# Telegram Bot API token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your personal Telegram user ID (from @userinfobot or @getmyid_bot)
ALLOWED_USER_ID=123456789

# RSS
RSS_BASE_URL=https://rss.nodeseek.com/
POLL_INTERVAL=60
MAX_NOTIFICATIONS_PER_POLL=10
RSS_FAIL_ALERT_THRESHOLD=3

# SQLite
DATABASE_PATH=data/nodeseek-rss.db
SEEN_POSTS_RETENTION_DAYS=30
NOTIFICATIONS_RETENTION_DAYS=30
CLEANUP_INTERVAL_HOURS=24

# Logs
LOG_DIR=logs
LOG_FILE=nodeseek-rss.log
LOG_MAX_BYTES=104857600
LOG_BACKUP_COUNT=1

# Email via Resend only
EMAIL_ENABLED=true
RESEND_API_KEY=
RESEND_FROM=NodeSeek Monitor <onboarding@resend.dev>
RESEND_TO=
RESEND_API_URL=https://api.resend.com/emails
EMAIL_TIMEOUT_SECONDS=20
